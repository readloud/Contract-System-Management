{
  "name": "cms-realtime",
  "version": "1.0.0",
  "description": "Hocuspocus server for Yjs real-time collaboration",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=11.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "start:prod": "node dist/index.js",
    "clean": "rm -rf dist node_modules package-lock.json"
  },
  "dependencies": {
    "@hocuspocus/extension-database": "^2.13.0",
    "@hocuspocus/extension-logger": "^2.13.0",
    "@hocuspocus/extension-redis": "^2.13.0",
    "@hocuspocus/server": "^2.13.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "redis": "^4.7.0",
    "yjs": "^13.6.15"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}