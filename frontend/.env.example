# ============================================
# CONTRACT MANAGEMENT SYSTEM - FRONTEND (Next.js)
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env.development, .env.production, or .env.docker
# Note: Only variables with NEXT_PUBLIC_ prefix are exposed to browser
# ============================================

# ============================================
# NEXT.JS APP CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_NAME=CMS Indonesia
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:1234
NEXT_PUBLIC_CDN_URL=

# ============================================
# FEATURE FLAGS (Enable/Disable features)
# ============================================
NEXT_PUBLIC_ENABLE_REDLINING=true
NEXT_PUBLIC_ENABLE_REALTIME_COLLAB=true
NEXT_PUBLIC_ENABLE_E_METERAI=true
NEXT_PUBLIC_ENABLE_WHATSAPP=true
NEXT_PUBLIC_ENABLE_BIOMETRIC_LOGIN=false
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_EXPORT_PDF=true
NEXT_PUBLIC_ENABLE_BULK_SIGNING=true

# ============================================
# AUTHENTICATION (NextAuth.js)
# ============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_min_32_characters_long
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_PROVIDER_CREDENTIALS_ENABLED=true

# OAuth Providers (Optional)
# Google
NEXTAUTH_GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXTAUTH_GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# ANALYTICS & MONITORING
# ============================================
# Google Analytics (GA4)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxx
SENTRY_ENVIRONMENT=development
SENTRY_ORG=your-org
SENTRY_PROJECT=cms-frontend

# Hotjar (User behavior analytics)
NEXT_PUBLIC_HOTJAR_ID=xxxxxxxxxxxx

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Maximum file size in bytes (10MB default)
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
# Maximum file size for bulk upload (50MB)
NEXT_PUBLIC_MAX_BULK_UPLOAD_SIZE=52428800
# Allowed file types
NEXT_PUBLIC_ALLOWED_FILE_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
# Maximum number of files per upload
NEXT_PUBLIC_MAX_FILES_PER_UPLOAD=10

# ============================================
# REAL-TIME COLLABORATION (Yjs + Hocuspocus)
# ============================================
NEXT_PUBLIC_COLLABORATION_ENABLED=true
NEXT_PUBLIC_COLLABORATION_WS_RECONNECT_INTERVAL=3000
NEXT_PUBLIC_COLLABORATION_MAX_RECONNECT_ATTEMPTS=10
NEXT_PUBLIC_COLLABORATION_WS_HEARTBEAT_INTERVAL=30000
NEXT_PUBLIC_COLLABORATION_AUTO_SAVE_INTERVAL=5000

# ============================================
# REDLINING / DIFF CONFIGURATION
# ============================================
NEXT_PUBLIC_REDLINING_HIGHLIGHT_COLOR_INSERT=#d4fcbc
NEXT_PUBLIC_REDLINING_HIGHLIGHT_COLOR_DELETE=#fcbcbc
NEXT_PUBLIC_REDLINING_HIGHLIGHT_COLOR_REPLACE=#fce8bc
NEXT_PUBLIC_REDLINING_VIEW_MODE=split

# ============================================
# UI & THEMING CONFIGURATION
# ============================================
NEXT_PUBLIC_DEFAULT_THEME=light
NEXT_PUBLIC_DEFAULT_LOCALE=id
NEXT_PUBLIC_DATE_FORMAT=DD/MM/YYYY
NEXT_PUBLIC_TIME_FORMAT=HH:mm
NEXT_PUBLIC_TIMEZONE=Asia/Jakarta
NEXT_PUBLIC_CURRENCY=IDR
NEXT_PUBLIC_CURRENCY_SYMBOL=Rp
NEXT_PUBLIC_CURRENCY_LOCALE=id-ID
NEXT_PUBLIC_NUMBER_FORMAT=decimal
NEXT_PUBLIC_THOUSAND_SEPARATOR=.
NEXT_PUBLIC_DECIMAL_SEPARATOR=,

# ============================================
# API & NETWORK CONFIGURATION
# ============================================
# Request timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_UPLOAD_TIMEOUT=60000
NEXT_PUBLIC_DOWNLOAD_TIMEOUT=120000
NEXT_PUBLIC_API_RETRY_COUNT=3
NEXT_PUBLIC_API_RETRY_DELAY=1000

# ============================================
# PAGINATION DEFAULTS
# ============================================
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=10
NEXT_PUBLIC_PAGE_SIZE_OPTIONS=10,25,50,100

# ============================================
# NOTIFICATION PREFERENCES
# ============================================
NEXT_PUBLIC_NOTIFICATION_DURATION=5000
NEXT_PUBLIC_NOTIFICATION_POSITION=topRight
NEXT_PUBLIC_ENABLE_SOUND_NOTIFICATION=false

# ============================================
# IMAGE OPTIMIZATION
# ============================================
NEXT_PUBLIC_IMAGE_OPTIMIZATION_ENABLED=true
NEXT_PUBLIC_IMAGE_QUALITY=75
NEXT_PUBLIC_IMAGE_FORMAT=webp

# ============================================
# SERVICE WORKER & PWA
# ============================================
NEXT_PUBLIC_PWA_ENABLED=false
NEXT_PUBLIC_SERVICE_WORKER_SCOPE=/

# ============================================
# CHAT & SUPPORT (Optional)
# ============================================
# Intercom
NEXT_PUBLIC_INTERCOM_APP_ID=xxxxxxxxxxxx

# Freshdesk
NEXT_PUBLIC_FRESHDESK_WIDGET_ID=xxxxxxxxxxxx

# WhatsApp Chat Widget
NEXT_PUBLIC_WHATSAPP_SUPPORT_NUMBER=6281234567890
NEXT_PUBLIC_WHATSAPP_WELCOME_MESSAGE=Halo, saya butuh bantuan dengan kontrak.

# ============================================
# RECAPTCHA (Security)
# ============================================
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# ============================================
# MAPS (For location verification if needed)
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_MAP_DEFAULT_CENTER=-6.2088,106.8456
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=11

# ============================================
# VERSION & BUILD INFO
# ============================================
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_BUILD_NUMBER=1

# ============================================
# DEBUG & DEVELOPMENT TOOLS
# ============================================
# Enable React Query devtools
NEXT_PUBLIC_ENABLE_DEVTOOLS=false
# Enable Redux devtools
NEXT_PUBLIC_ENABLE_REDUX_DEVTOOLS=false
# Show debug logs in console
NEXT_PUBLIC_DEBUG_MODE=false
# Mock API responses (for testing without backend)
NEXT_PUBLIC_MOCK_API=false

# ============================================
# SEARCH ENGINE OPTIMIZATION (SEO)
# ============================================
NEXT_PUBLIC_SITE_TITLE=CMS Indonesia - Platform Manajemen Kontrak Digital
NEXT_PUBLIC_SITE_DESCRIPTION=Sistem manajemen kontrak dengan tanda tangan elektronik tersertifikasi dan e-Meterai sesuai hukum Indonesia
NEXT_PUBLIC_SITE_KEYWORDS=contract management, e-signature, e-meterai, digital signature, legal tech
NEXT_PUBLIC_SITE_AUTHOR=Your Company Name
NEXT_PUBLIC_OG_IMAGE=/og-image.png
NEXT_PUBLIC_TWITTER_HANDLE=@cms_indonesia

# ============================================
# ============================================
# END OF CONFIGURATION
# ============================================
# IMPORTANT: 
# 1. NEVER commit .env.local or .env.production to git
# 2. Only .env.example should be committed
# 3. Keep NEXT_PUBLIC_* variables only for browser-safe values
# 4. Store sensitive keys (API keys, secrets) in backend only
# ============================================