# ============================================
# CONTRACT MANAGEMENT SYSTEM - BACKEND
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env.development, .env.production, or .env.docker
# and fill in the values according to your environment
# ============================================

# ============================================
# NODE & SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
APP_NAME=CMS-Backend
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_NAME=cms_db
DB_SYNC=false
DB_LOGGING=true
DB_MAX_CONNECTIONS=10
DB_SSL=false
DB_SSL_CA_PATH=

# ============================================
# REDIS (Cache & Queue)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_min_32_characters_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_min_32_characters_long
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# AWS S3 (Document Storage with AES-256 Encryption)
# ============================================
# Region: ap-southeast-1 (Singapore), ap-southeast-3 (Jakarta)
AWS_REGION=ap-southeast-3
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=cms-documents
AWS_S3_ENDPOINT=https://s3.ap-southeast-3.amazonaws.com
AWS_S3_FORCE_PATH_STYLE=false
S3_SSE_TYPE=AES256
S3_PRESIGNED_URL_EXPIRY=3600

# ============================================
# PRIVYID (Certified Digital Signature - PSrE)
# ============================================
# Register at: https://dashboard.privy.id
PRIVY_API_BASE_URL=https://api.privy.id
PRIVY_API_VERSION=v1
PRIVY_CLIENT_ID=your_privy_client_id
PRIVY_CLIENT_SECRET=your_privy_client_secret
PRIVY_REDIRECT_URI=https://your-domain.com/api/v1/signatures/callback
PRIVY_WEBHOOK_SECRET=your_privy_webhook_secret

# For sandbox environment (development)
PRIVY_SANDBOX_API_BASE_URL=https://sandbox-api.privy.id
PRIVY_SANDBOX_CLIENT_ID=your_sandbox_client_id
PRIVY_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret

# ============================================
# PERURI E-METERAI (Official e-Meterai from Peruri Digital Security)
# ============================================
# Register at: https://peruri.co.id/digital-security
PERURI_API_BASE_URL=https://api.peruri.co.id/v1
PERURI_CLIENT_ID=your_peruri_client_id
PERURI_CLIENT_SECRET=your_peruri_client_secret
PERURI_VENDOR_CODE=YOUR_VENDOR_CODE
PERURI_RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Sandbox environment
PERURI_SANDBOX_API_BASE_URL=https://sandbox-api.peruri.co.id/v1
PERURI_SANDBOX_CLIENT_ID=your_sandbox_client_id
PERURI_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret

# ============================================
# MITRAKAS E-METERAI (Alternate e-Meterai Provider)
# ============================================
# Register at: https://mitrakas.com
MITRAKAS_API_BASE_URL=https://api.mitrakas.com/v1
MITRAKAS_API_KEY=your_mitrakas_api_key
MITRAKAS_API_SECRET=your_mitrakas_api_secret
MITRAKAS_MERCHANT_ID=YOUR_MERCHANT_ID

# Sandbox environment
MITRAKAS_SANDBOX_API_BASE_URL=https://sandbox.mitrakas.com/v1
MITRAKAS_SANDBOX_API_KEY=your_sandbox_api_key
MITRAKAS_SANDBOX_API_SECRET=your_sandbox_api_secret

# ============================================
# VIDA (Alternative PSrE Provider)
# ============================================
# Register at: https://vida.id
VIDA_API_BASE_URL=https://api.vida.id/v1
VIDA_CLIENT_ID=your_vida_client_id
VIDA_CLIENT_SECRET=your_vida_client_secret
VIDA_PARTNER_CODE=YOUR_PARTNER_CODE

# Sandbox environment
VIDA_SANDBOX_API_BASE_URL=https://sandbox-api.vida.id/v1
VIDA_SANDBOX_CLIENT_ID=your_sandbox_client_id
VIDA_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret

# ============================================
# SENDGRID (Email Notifications)
# ============================================
# Register at: https://sendgrid.com
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@your-domain.com
SENDGRID_FROM_NAME=Contract Management System

# Dynamic Templates (create in SendGrid dashboard)
SENDGRID_TEMPLATE_WELCOME=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_CONTRACT_READY=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_SIGNATURE_REQUEST=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_CONTRACT_EXPIRING=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_METERAI_APPLIED=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Enable sandbox mode for development
SENDGRID_SANDBOX_MODE=false

# ============================================
# WHATSAPP BUSINESS API (Meta/Facebook)
# ============================================
# Register at: https://business.facebook.com/wa
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=456789012345678
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/whatsapp

# ============================================
# BULL QUEUE (Background Jobs)
# ============================================
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=
BULL_DEFAULT_JOB_ATTEMPTS=3
BULL_DEFAULT_BACKOFF_DELAY=5000
BULL_QUEUE_PREFIX=cms

# ============================================
# RATE LIMITING
# ============================================
# Number of seconds to keep rate limit data
RATE_LIMIT_TTL=60
# Maximum number of requests within TTL window
RATE_LIMIT_MAX_REQUESTS=100
# Enable rate limiting for API endpoints
RATE_LIMIT_ENABLED=true

# ============================================
# LOGGING
# ============================================
# Log levels: error, warn, info, debug, verbose
LOG_LEVEL=debug
LOG_FILE_PATH=logs/app.log
LOG_MAX_FILES=14
LOG_MAX_SIZE=20m

# Slack webhook for error notifications (optional)
LOG_SLACK_WEBHOOK=https://hooks.slack.com/services/xxxxx/xxxxx/xxxxxxxx

# ============================================
# MONITORING & ALERTING (Optional)
# ============================================
# Sentry for error tracking
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxx
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Datadog APM (optional)
DATADOG_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATADOG_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATADOG_SERVICE_NAME=cms-backend

# ============================================
# HEALTH CHECK
# ============================================
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_RETRY_COUNT=3

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_TEMP_DIR=/tmp/cms-uploads

# ============================================
# ENCRYPTION KEYS (For sensitive data)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_encryption_key_hex
ENCRYPTION_IV=your_16_byte_encryption_iv_hex

# ============================================
# COOKIE & SESSION
# ============================================
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax
SESSION_TIMEOUT=3600000

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_REDLINING_ENABLED=true
FEATURE_REALTIME_COLLAB_ENABLED=true
FEATURE_E_METERAI_ENABLED=true
FEATURE_WHATSAPP_ENABLED=true
FEATURE_EXPORT_PDF_ENABLED=true

# ============================================
# DEMO / SEEDING DATA (Development only)
# ============================================
DEMO_MODE=false
DEMO_ADMIN_EMAIL=admin@cms.com
DEMO_ADMIN_PASSWORD=Admin123!

# ============================================
# EXTERNAL SERVICES
# ============================================
# Google Maps API (for location verification if needed)
GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OCR Service (for scanned documents)
OCR_API_BASE_URL=https://api.ocr.space
OCR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# ============================================
# END OF CONFIGURATION
# ============================================
# IMPORTANT: Never commit real credentials to git!
# Always use .env.local or .env.production for actual secrets